{
  "name": "stalescope",
  "version": "0.1.0",
  "description": "Next.js App Router cache inspector and debug dashboard. Make the invisible cache visible.",
  "keywords": [
    "nextjs",
    "cache",
    "debug",
    "app-router",
    "instrumentation",
    "memory-leak",
    "stale",
    "revalidate",
    "react-server-components"
  ],
  "author": "Abdul Moiz",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "peerDependencies": {
    "next": ">=14"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "next": "^14.0.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.0.0"
  }
}
